manifest {
    author = 'Jeremy Guerrero'
    name = 'RNA2DEG-NF'
    description = 'Modular Nextflow DSL2 pipeline for RNA-seq download, manifest generation, and DEG preprocessing'
    mainScript = 'main.nf'
    version = '0.1.0'
}

nextflow.enable.dsl = 2

params {
    /*
     * Input source selection
     * Supported:
     *   - sra_open
     *   - sra_restricted
     *   - gdc
     */
    source = null

    /*
     * Input files
     */
    accession_file = null
    manifest_file = null

    /*
     * Download and manifest generation
     */
    samples_dir = null
    mode = null
    samplesheet_script_ch = null

    /*
     * Reference files for DEG preprocessing
     */
    index = null
    gtf = null

    /*
     * Optional credentials
     */
    ngc_key = null
    gdc_token = null

    /*
     * Download behavior
     */
    prefetch_max_size = '50g'

    /*
     * Output / logs
     */
    outdir = "./results"
    log_dir = "./logs"

    run_name = "run"

    /*
     * Stage-specific publish directories
     */
    prefastqc_dir  = "${params.outdir}/qc/pre_trim"
    trim_fastq_dir = "${params.outdir}/trimmed_fastq"
    postfastqc_dir = "${params.outdir}/qc/post_trim"
    bam_dir        = "${params.outdir}/bam"
    table_dir      = "${params.outdir}/tables"
    manifest_dir   = "${params.outdir}/manifest"
    download_dir   = "${params.outdir}/downloads"
}

process {
    executor = 'slurm'
    errorStrategy = { task.attempt < 3 ? 'retry' : 'terminate' }
    maxRetries = 2

    /*
     * Default resources
     */
    cpus = 1
    memory = '2 GB'
    time = '1h'

    /*
     * Download / manifest labels
     */
    withLabel: prefetch_prof {
        cpus = 2
        memory = '8 GB'
        time = '6h'
        maxForks = 4
    }

    withLabel: validate_prof {
        cpus = 1
        memory = '2 GB'
        time = '1h'
        maxForks = 10
    }

    withLabel: fasterqdump_prof {
        cpus = 4
        memory = '16 GB'
        time = '8h'
        maxForks = 4
    }

    withLabel: metadata_prof {
        cpus = 1
        memory = '2 GB'
        time = '1h'
        maxForks = 10
    }

    withLabel: gdc_prof {
        cpus = 2
        memory = '8 GB'
        time = '8h'
        maxForks = 4
    }

    withLabel: md5_prof {
        cpus = 1
        memory = '1 GB'
        time = '1h'
        maxForks = 10
    }

    withLabel: csv_prof {
        cpus = 1
        memory = '2 GB'
        time = '1h'
        maxForks = 10
    }

    /*
     * DEG preprocessing labels
     */
    withLabel: fastq_prof {
        cpus = 2
        memory = '5 GB'
        time = '1h'
        maxForks = 12
    }

    withLabel: fastqstar_prof {
        cpus = 6
        memory = '35 GB'
        time = '2h'
        maxForks = 10
    }

    withLabel: counts_prof {
        cpus = 2
        memory = '3 GB'
        time = '1h'
        maxForks = 25
    }
}

conda {
    enabled = true
    cacheDir = "${projectDir}/.conda"
}

dag {
    enabled = true
    direction = 'LR'
    file = "${params.log_dir}/dag-${params.run_name}.html"
    overwrite = true
}

report {
    enabled = true
    file = "${params.log_dir}/report-${params.run_name}.html"
    overwrite = true
}

timeline {
    enabled = true
    file = "${params.log_dir}/timeline-${params.run_name}.html"
    overwrite = true
}

trace {
    enabled = true
    file = "${params.log_dir}/trace-${params.run_name}.txt"
    overwrite = true
}